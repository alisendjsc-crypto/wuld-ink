# wuld.ink .gitignore
# Deploy artifacts (Cloudflare Pages now pulls from main branch)
*.zip
*.tar.gz
wuld-ink-deploy*
ziCwRmw0
ziGq6fkD
zi[A-Za-z0-9]*

# Editor / IDE
.vscode/
.idea/
*.swp
*~
*.bak

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Node (in case build tooling ever lands)
node_modules/
.env
.env.local

# Cowork session artifacts (none currently expected, but defensive)
outputs/

# Audio conversion staging — MP3s land here mid-session for R2 upload.
# Never ship to git; audio is hosted on audio.wuld.ink (R2 bucket wuld-audio).
_audio-staging/

# Procmon traces — multi-GB binary; analyzed Josiah-side via procmon-parser
# Python script (scripts/analyze_procmon.py). Never ship raw .pml to git.
*.pml
*.PML
docs/Procmon-*.pml
docs/Procmon-*.PML

# Procmon CSV outputs from analyze_procmon.py — analysis artifacts, kept
# Josiah-side for forensic reference but not part of wuld.ink repo.
k*-trace.csv
docs/k*-trace.csv

# Library publication artifacts (K17+ landed Josiah-side from library-Claude
# coordination session output). These belong in the library GitHub repo
# (alisendjsc-crypto/efilist-argument-library), NOT wuld.ink. Staged here
# only because Josiah's working folder is shared. Deferred to dedicated
# library publication coordination session per K17 lock.
docs/LICENSE
docs/LICENSE-CODE
docs/README.md
docs/CITATION_cff_*.cff
docs/RELEASE_NOTES_v*.md
docs/OPERATOR_CHECKLIST_*.md
docs/cowork_orientation_v*.md
docs/library_claude_coordination_EXCHANGE_*_FRAGMENT.md

# Procmon CSV outputs from analyze_procmon.py — analysis artifacts, kept
# Josiah-side for forensic reference but not part of wuld.ink repo.
k*-trace.csv
docs/k*-trace.csv

# Library publication artifacts (K17+ landed Josiah-side from library-Claude
# coordination session output). These belong in the library GitHub repo
# (alisendjsc-crypto/efilist-argument-library), NOT wuld.ink. Staged here
# only because Josiah's working folder is shared. Deferred to dedicated
# library publication coordination session per K17 lock.
docs/LICENSE
docs/LICENSE-CODE
docs/README.md
docs/CITATION_cff_*.cff
docs/RELEASE_NOTES_v*.md
docs/OPERATOR_CHECKLIST_*.md
docs/cowork_orientation_v*.md
docs/library_claude_coordination_EXCHANGE_*_FRAGMENT.md
