# wuld.ink .gitignore
# Deploy artifacts (Cloudflare Pages now pulls from main branch)
*.zip
*.tar.gz
wuld-ink-deploy*
ziCwRmw0
ziGq6fkD
zi[A-Za-z0-9]*

# Editor / IDE
.vscode/
.idea/
*.swp
*~
*.bak

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Node (in case build tooling ever lands)
node_modules/
.env
.env.local

# Cowork session artifacts (none currently expected, but defensive)
outputs/

# Audio conversion staging — MP3s land here mid-session for R2 upload.
# Never ship to git; audio is hosted on audio.wuld.ink (R2 bucket wuld-audio).
_audio-staging/

# Procmon traces — multi-GB binary; analyzed Josiah-side via procmon-parser
# Python script (scripts/analyze_procmon.py). Never ship raw .pml to git.
*.pml
*.PML
docs/Procmon-*.pml
docs/Procmon-*.PML
